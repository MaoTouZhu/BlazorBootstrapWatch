@rendermode InteractiveServer
@inject FloatingPopupService PopupService
@inject IJSRuntime JS
@implements IDisposable

@if (PopupService.Visible)
{
    <div class="position-fixed shadow-lg rounded"
         style="left:@(PopupService.X.ToString("F0"))px;top:@(PopupService.Y.ToString("F0"))px;
                z-index:9999;min-width:300px;@(dragging ? "cursor:grabbing;opacity:0.95" : "")"
         @onmousemove="OnMove"
         @onmouseup="OnUp">

        <div class="bg-primary text-white rounded-top px-3 py-2 d-flex justify-content-between align-items-center"
             @onmousedown="StartDrag" @onmousedown:stopPropagation
             style="cursor:grab;user-select:none">
            <strong>@PopupService.Title</strong>
            <button class="btn-close btn-close-white" @onclick="Close" @onclick:stopPropagation
                    title="关闭 (Close)"></button>
        </div>

        <div class="bg-white border border-top-0 rounded-bottom p-3">
            <p class="mb-2">@PopupService.Message</p>
            <p class="small text-muted mb-0">
                💡 此弹窗跨页面持久 — 切换页面不会消失，除非主动关闭。
            </p>
            <p class="small text-muted mb-0">
                📍 当前位置：@(PopupService.X.ToString("F0")), @(PopupService.Y.ToString("F0"))
            </p>
        </div>
    </div>
}

@code {
    private bool dragging;
    private double startClientX, startClientY, startX, startY;
    private int moveCount;

    protected override void OnInitialized()
    {
        PopupService.OnChanged += StateHasChanged;
    }

    private async void StartDrag(MouseEventArgs e)
    {
        dragging = true;
        moveCount = 0;
        startClientX = e.ClientX;
        startClientY = e.ClientY;
        startX = PopupService.X;
        startY = PopupService.Y;
        await JS.InvokeVoidAsync("console.log",
            $"[Popup] 🖱️ mousedown  client=({e.ClientX:F0},{e.ClientY:F0})  popup=({startX:F0},{startY:F0})");
    }

    private async void OnMove(MouseEventArgs e)
    {
        moveCount++;
        var newX = startX + (e.ClientX - startClientX);
        var newY = startY + (e.ClientY - startClientY);
        if (moveCount <= 5 || moveCount % 10 == 0)
            await JS.InvokeVoidAsync("console.log",
                $"[Popup] ↔ mousemove #{moveCount}  client=({e.ClientX:F0},{e.ClientY:F0}) → ({newX:F0},{newY:F0})" + (dragging ? "" : " ⚠️dragging=false!"));
        if (!dragging) return;
        PopupService.X = newX;
        PopupService.Y = newY;
        PopupService.Notify();
    }

    private async void OnUp()
    {
        if (!dragging) { await JS.InvokeVoidAsync("console.warn", $"[Popup] ⚠️ mouseup 但 dragging 已经是 false (moveCount={moveCount})"); return; }
        await JS.InvokeVoidAsync("console.log", $"[Popup] ✅ 松开 mouseup  moveCount={moveCount}  最终位置=({PopupService.X:F0},{PopupService.Y:F0})");
        dragging = false;
    }

    private async void Close() { await JS.InvokeVoidAsync("console.log", "[Popup] ✕ 关闭弹窗"); PopupService.Close(); }

    public void Dispose() => PopupService.OnChanged -= StateHasChanged;
}
