@rendermode InteractiveServer
@inject FloatingPopupService PopupService
@inject IJSRuntime JS
@implements IDisposable
@implements IAsyncDisposable

@if (PopupService.Visible)
{
    <div class="position-fixed shadow-lg rounded"
         style="left:@(PopupService.X.ToString("F0"))px;top:@(PopupService.Y.ToString("F0"))px;
                z-index:9999;min-width:300px;@(dragging ? "opacity:0.95" : "")"
         id="floating-popup">

        <div class="bg-primary text-white rounded-top px-3 py-2 d-flex justify-content-between align-items-center"
             @onmousedown="StartDrag" @onmousedown:stopPropagation
             style="cursor:grab;user-select:none">
            <strong>@PopupService.Title</strong>
            <button class="btn-close btn-close-white" @onclick="Close" @onclick:stopPropagation
                    title="关闭 (Close)"></button>
        </div>

        <div class="bg-white border border-top-0 rounded-bottom p-3">
            <p class="mb-2">@PopupService.Message</p>
            <p class="small text-muted mb-0">
                💡 此弹窗跨页面持久 — 切换页面不会消失，除非主动关闭。
            </p>
            <p class="small text-muted mb-0">
                📍 当前位置：@(PopupService.X.ToString("F0")), @(PopupService.Y.ToString("F0"))
            </p>
        </div>
    </div>
}

@code {
    private bool dragging;
    private IJSObjectReference? dragModule;

    protected override async Task OnInitializedAsync()
    {
        PopupService.OnChanged += StateHasChanged;
        dragModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/popup-drag.js");
    }

    private async void StartDrag(MouseEventArgs e)
    {
        dragging = true;
        StateHasChanged();

        if (dragModule != null)
        {
            var dotNetRef = DotNetObjectReference.Create(this);
            await dragModule.InvokeVoidAsync("beginDrag", dotNetRef,
                PopupService.X, PopupService.Y, e.ClientX, e.ClientY);
        }
    }

    [JSInvokable]
    public void OnDragUpdate(double newX, double newY)
    {
        PopupService.X = newX;
        PopupService.Y = newY;
        PopupService.Notify();
    }

    [JSInvokable]
    public void OnDragEnd()
    {
        dragging = false;
        StateHasChanged();
    }

    private void Close() => PopupService.Close();

    public void Dispose() => PopupService.OnChanged -= StateHasChanged;

    public async ValueTask DisposeAsync()
    {
        if (dragModule != null)
            await dragModule.DisposeAsync();
    }
}
