@page "/loading"
@rendermode InteractiveServer

<PageTitle>Loading States - Bootstrap Showcase</PageTitle>

<h2>⏳ Loading States</h2>
<p class="lead">Progress bars, spinners, and placeholder loading animations.</p>

<h5 class="mt-4">Progress Bars</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="progress mb-3" style="height:20px">
        <div class="progress-bar" style="width:0%">0%</div>
    </div>
    <div class="progress mb-3" style="height:20px">
        <div class="progress-bar w-25">25%</div>
    </div>
    <div class="progress mb-3" style="height:20px">
        <div class="progress-bar w-50">50%</div>
    </div>
    <div class="progress mb-3" style="height:20px">
        <div class="progress-bar w-75">75%</div>
    </div>
    <div class="progress mb-3" style="height:20px">
        <div class="progress-bar w-100">100%</div>
    </div>
</div>

<h5>Colored & Multiple Bars</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="progress mb-3">
        @foreach (var c in new[]{"primary","success","info","warning","danger"})
        {
            <div class="progress-bar bg-@c" style="width:15%">@c</div>
        }
    </div>
    <div class="progress mb-3">
        <div class="progress-bar bg-success" style="width:35%">35% Free</div>
        <div class="progress-bar bg-warning text-dark" style="width:20%">20% Used</div>
        <div class="progress-bar bg-danger" style="width:10%">10% Hot</div>
    </div>
</div>

<h5>Striped & Animated</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="progress mb-3">
        <div class="progress-bar progress-bar-striped w-75">Striped</div>
    </div>
    <div class="progress mb-3">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-50">Animated</div>
    </div>
    <div class="progress mb-3">
        <div class="progress-bar bg-success progress-bar-striped progress-bar-animated w-100">Loading...</div>
    </div>
</div>

<h5>Animated Progress Bar (Blazor)</h5>
<div class="border rounded p-4 bg-light mb-4 text-center">
    <div class="progress mb-3" style="height:25px">
        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width:@progressValue%">
            @progressValue%
        </div>
    </div>
    <button class="btn btn-sm btn-primary me-1" @onclick="StartProgress" disabled="@isRunning">▶ Start</button>
    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="PauseProgress" disabled="@(!isRunning)">⏸ Pause</button>
    <button class="btn btn-sm btn-outline-danger" @onclick="ResetProgress" disabled="@(progressValue == 0 && !isRunning)">↺ Reset</button>
    <p class="mt-2 small text-muted">Blazor-driven progress bar with timer.</p>
</div>

<h5 class="mt-4">Spinners</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="d-flex flex-wrap gap-4 align-items-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="spinner-border text-success" role="status"></div>
        <div class="spinner-border text-danger" role="status"></div>
        <div class="spinner-border text-warning" role="status"></div>
        <div class="spinner-border text-info" role="status"></div>
        <div class="spinner-border text-secondary" role="status"></div>
    </div>
    <p class="mt-3 mb-0 small text-muted">Border spinners in all theme colors.</p>
</div>

<div class="border rounded p-4 bg-light mb-4">
    <div class="d-flex flex-wrap gap-4 align-items-center">
        <div class="spinner-grow text-primary" role="status"></div>
        <div class="spinner-grow text-success" role="status"></div>
        <div class="spinner-grow text-danger" role="status"></div>
        <div class="spinner-grow text-warning" role="status"></div>
        <div class="spinner-grow text-info" role="status"></div>
    </div>
    <p class="mt-3 mb-0 small text-muted">Growing spinners in all theme colors.</p>
</div>

<h5>Spinner Sizes</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="d-flex flex-wrap gap-4 align-items-end">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <div class="spinner-border" role="status"></div>
        <div class="spinner-border" style="width:3rem;height:3rem" role="status"></div>
    </div>
    <p class="mt-3 mb-0 small text-muted">Small, default, and custom-sized spinners.</p>
</div>

<h5>Spinners in Buttons</h5>
<div class="border rounded p-4 bg-light mb-4">
    <button class="btn btn-primary me-2" type="button" disabled>
        <span class="spinner-border spinner-border-sm me-1"></span> Loading...
    </button>
    <button class="btn btn-success me-2" type="button" disabled>
        <span class="spinner-grow spinner-grow-sm me-1"></span> Saving...
    </button>
    <button class="btn btn-outline-primary" type="button" @onclick="ToggleLoading">
        @(isLoading ? "⏳ Processing..." : "Submit")
        @if (isLoading)
        {
            <span class="spinner-border spinner-border-sm ms-1"></span>
        }
    </button>
</div>

<h5 class="mt-4">Placeholders</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title placeholder-glow">
                <span class="placeholder col-6"></span>
            </h5>
            <p class="card-text placeholder-glow">
                <span class="placeholder col-7"></span>
                <span class="placeholder col-4"></span>
                <span class="placeholder col-4"></span>
                <span class="placeholder col-6"></span>
                <span class="placeholder col-8"></span>
            </p>
            <a href="#" tabindex="-1" class="btn btn-primary disabled placeholder col-4"></a>
        </div>
    </div>
</div>

<h5>Placeholder Sizes & Colors</h5>
<div class="border rounded p-4 bg-light mb-4">
    <span class="placeholder col-12 placeholder-lg mb-2 d-block"></span>
    <span class="placeholder col-12 mb-2 d-block"></span>
    <span class="placeholder col-12 placeholder-sm mb-2 d-block"></span>
    <span class="placeholder col-12 placeholder-xs d-block"></span>
</div>

<h5>Placeholder with Animation</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="card">
        <div class="card-body placeholder-glow">
            <span class="placeholder col-2 rounded-circle me-3" style="width:50px;height:50px"></span>
            <span class="placeholder col-8 placeholder-lg"></span>
            <span class="placeholder col-5 mt-2 d-block"></span>
        </div>
    </div>
    <p class="mt-2 small text-muted">Add <code>.placeholder-wave</code> for wave animation on individual placeholders.</p>
    <span class="placeholder col-12 bg-primary placeholder-wave"></span>
</div>

@code {
    private int progressValue;
    private bool isRunning;
    private bool isLoading;
    private System.Threading.Timer? timer;

    private void StartProgress()
    {
        isRunning = true;
        timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (progressValue < 100) progressValue += 2;
                else { isRunning = false; timer?.Dispose(); }
                StateHasChanged();
            });
        }, null, 0, 150);
    }

    private void PauseProgress() { isRunning = false; timer?.Dispose(); }
    private void ResetProgress() { isRunning = false; timer?.Dispose(); progressValue = 0; }
    private async void ToggleLoading() { isLoading = true; StateHasChanged(); await Task.Delay(2000); isLoading = false; StateHasChanged(); }
}
