@page "/global-shortcuts"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>全局快捷键 (Global Shortcuts) - Blazor 特性</PageTitle>

<h2>⌨️ 全局快捷键 (Global Shortcuts)</h2>
<p class="lead">通过 JavaScript 全局键盘事件监听，在 Blazor 应用中实现跨页面快捷键。</p>

<div class="row g-4">
    <div class="col-lg-8">
        <!-- 按键捕获区域 -->
        <div class="border rounded p-4 bg-light mb-4"
             @onkeydown="OnKeyDown" @onkeydown:preventDefault
             tabindex="-1" @ref="keyCaptureArea">
            <h5>⌨️ 实时按键日志 <small class="text-muted">(Key Log — 最近 100 条)</small></h5>
            <p class="small text-muted">
                点击本区域后，在此页面按下的键盘事件将被记录。
                Ctrl+H 仍然会触发全局快捷键返回首页。
            </p>
            <div class="border rounded bg-dark text-light p-3 font-monospace small"
                 style="height:280px;overflow-y:auto" @ref="logContainer">
                @if (keyLog.Count == 0)
                {
                    <span class="text-muted">点击上方区域或按任意键开始记录...</span>
                }
                else
                {
                    @foreach (var entry in keyLog)
                    {
                        <div class="d-flex" style="line-height:1.6">
                            <span class="text-info me-2" style="min-width:85px">@entry.Time</span>
                            <span class="text-warning me-2" style="min-width:100px">@entry.Modifiers</span>
                            <span class="text-success me-2" style="min-width:80px">key: @entry.Key</span>
                            <span class="text-secondary me-2" style="min-width:90px">code: @entry.Code</span>
                            @if (!string.IsNullOrEmpty(entry.Ctrl))
                            {
                                <span class="text-danger">@entry.Ctrl</span>
                            }
                        </div>
                    }
                }
            </div>
            <div class="mt-2 d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearLog">🗑 清空日志</button>
                <button class="btn btn-sm btn-outline-primary" @onclick="FocusArea">🎯 聚焦捕获区域</button>
                <small class="text-muted ms-auto align-self-center">共 @keyLog.Count 条记录</small>
            </div>
        </div>

        <div class="border rounded p-4 bg-light">
            <h5>可用快捷键</h5>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-dark">
                        <tr><th>快捷键</th><th>功能</th><th>说明</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><kbd>Ctrl</kbd> + <kbd>H</kbd></td>
                            <td>🏠 回到首页</td>
                            <td>任意页面按下即可跳转到首页 <code>/</code></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <h5 class="mt-4">排除场景</h5>
            <p>以下场景中快捷键<strong>不会</strong>触发，防止误操作：</p>
            <ul class="mb-0">
                <li><code>&lt;input&gt;</code> 输入框聚焦时</li>
                <li><code>&lt;textarea&gt;</code> 文本域聚焦时</li>
                <li><code>&lt;select&gt;</code> 下拉选择聚焦时</li>
                <li><code>contentEditable</code> 可编辑元素聚焦时</li>
            </ul>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="border rounded p-4 bg-light mb-4">
            <h5>日志字段说明</h5>
            <table class="table table-sm small mb-0">
                <tr><td class="text-info">时间</td><td>按键触发时刻</td></tr>
                <tr><td class="text-warning">修饰键</td><td>Ctrl / Shift / Alt / Meta</td></tr>
                <tr><td class="text-success">key</td><td>按键的字符值 (a, Enter, Escape...)</td></tr>
                <tr><td class="text-secondary">code</td><td>按键的物理位置码 (KeyA, Enter...)</td></tr>
                <tr><td class="text-danger">特殊</td><td>Ctrl+H → 触发回首页</td></tr>
            </table>
        </div>

        <div class="border rounded p-4 bg-light">
            <h5>实现代码</h5>
            <p class="small text-muted"><code>wwwroot/js/global-shortcuts.js</code></p>
            <div class="bg-dark text-light rounded p-3">
                <pre class="small mb-0"><code>function registerShortcuts() {
  document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'h') {
      var tag = document.activeElement?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' ||
          tag === 'SELECT' || document.activeElement
          ?.isContentEditable) return;
      e.preventDefault();
      window.location.href = '/';
    }
  });
}
registerShortcuts();
document.addEventListener('enhancedload', registerShortcuts);</code></pre>
            </div>

            <h5 class="mt-4">关键点</h5>
            <ul class="small mb-0">
                <li class="mb-2"><strong>全局 keydown</strong><br>在 <code>document</code> 上监听，覆盖全部页面</li>
                <li class="mb-2"><strong>Ctrl/Cmd 兼容</strong><br><code>e.ctrlKey || e.metaKey</code></li>
                <li class="mb-2"><strong>preventDefault</strong><br>阻止浏览器默认行为</li>
                <li class="mb-2"><strong>输入框排除</strong><br>检查 <code>activeElement</code></li>
                <li class="mb-2"><strong>enhancedload</strong><br>Blazor 增强导航后重新注册</li>
            </ul>
        </div>
    </div>
</div>

@code {
    private ElementReference keyCaptureArea;
    private ElementReference logContainer;

    private readonly List<KeyEntry> keyLog = new();
    private const int MaxEntries = 100;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await keyCaptureArea.FocusAsync();
        }
    }

    private async void OnKeyDown(KeyboardEventArgs e)
    {
        // Ctrl+H 由全局 JS 处理，此处仅记录
        var modifiers = new List<string>();
        if (e.CtrlKey) modifiers.Add("Ctrl");
        if (e.ShiftKey) modifiers.Add("Shift");
        if (e.AltKey) modifiers.Add("Alt");
        if (e.MetaKey) modifiers.Add("Meta");

        var entry = new KeyEntry
        {
            Time = DateTime.Now.ToString("HH:mm:ss.fff"),
            Modifiers = modifiers.Count > 0 ? string.Join("+", modifiers) : "—",
            Key = e.Key,
            Code = e.Code,
            Ctrl = (e.CtrlKey || e.MetaKey) && e.Key.Equals("h", StringComparison.OrdinalIgnoreCase)
                ? "→ 🏠 回首页" : ""
        };

        keyLog.Insert(0, entry);
        while (keyLog.Count > MaxEntries) keyLog.RemoveAt(keyLog.Count - 1);

        StateHasChanged();
    }

    private async void FocusArea() => await keyCaptureArea.FocusAsync();
    private void ClearLog() { keyLog.Clear(); }

    private class KeyEntry
    {
        public string Time { get; set; } = "";
        public string Modifiers { get; set; } = "";
        public string Key { get; set; } = "";
        public string Code { get; set; } = "";
        public string Ctrl { get; set; } = "";
    }
}
