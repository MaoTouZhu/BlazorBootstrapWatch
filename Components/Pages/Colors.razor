@page "/colors"

<PageTitle>Colors - Bootstrap Showcase</PageTitle>

<h2>🎨 Colors & Backgrounds</h2>
<p class="lead">Bootstrap's color system: theme colors, text colors, backgrounds, and gradients.</p>

<h5 class="mt-4">Theme Colors</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-4 col-sm-2 col-md text-center">
            <div class="bg-@c.Key text-white rounded p-3 mb-1">@c.Key</div>
            <small class="text-muted">@c.Value</small>
        </div>
    }
</div>

<h5 class="mt-4">Background Colors (with opacity)</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-4 col-sm-2 col-md text-center">
            <div class="bg-@c.Key bg-opacity-10 rounded p-3 mb-1 border">10%</div>
            <div class="bg-@c.Key bg-opacity-25 rounded p-3 mb-1 border">25%</div>
            <div class="bg-@c.Key bg-opacity-50 rounded p-3 mb-1 border">50%</div>
            <div class="bg-@c.Key bg-opacity-75 rounded p-3 mb-1 text-white">75%</div>
            <small class="text-muted">@c.Key</small>
        </div>
    }
</div>

<h5 class="mt-4">Text Colors</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-4 col-sm-2 col-md text-center">
            <span class="text-@c.Key fw-bold">text-@c.Key</span>
        </div>
    }
</div>
<div class="border rounded p-3 bg-light mb-3">
    <p class="text-muted">Muted text with <code>.text-muted</code></p>
    <p class="text-black-50">Black 50% opacity text</p>
    <p class="text-white-50 bg-dark p-2 rounded">White 50% opacity text on dark bg</p>
</div>

<h5 class="mt-4">Background Gradients</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors.Take(6))
    {
        <div class="col-4 col-sm-2 text-center">
            <div class="bg-@c.Key bg-gradient text-white rounded p-3">@c.Key gradient</div>
        </div>
    }
</div>

<h5 class="mt-4">Borders</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-auto mb-2">
            <span class="border border-@c.Key rounded p-2">border-@c.Key</span>
        </div>
    }
</div>
<div class="border rounded p-3 bg-light">
    <span class="border rounded p-2 m-1">rounded</span>
    <span class="border rounded-circle p-3 m-1">circle</span>
    <span class="border rounded-pill px-3 py-1 m-1">pill</span>
    <span class="border border-2 p-2 m-1">border-2</span>
    <span class="border border-4 p-2 m-1">border-4</span>
</div>

<h5 class="mt-4">Dark Mode</h5>
<div class="rounded p-4 text-bg-dark">
    <h5>Dark theme section</h5>
    <p>This uses <code>text-bg-dark</code> for dark background with light text.</p>
    <span class="badge text-bg-light">Light badge on dark</span>
</div>

<div class="rounded p-4 text-bg-secondary mt-3">
    <h5>Secondary theme section</h5>
    <p>Uses <code>text-bg-secondary</code>.</p>
</div>

@code {
    private readonly Dictionary<string, string> themeColors = new()
    {
        ["primary"] = "#0d6efd",
        ["secondary"] = "#6c757d",
        ["success"] = "#198754",
        ["danger"] = "#dc3545",
        ["warning"] = "#ffc107",
        ["info"] = "#0dcaf0",
        ["light"] = "#f8f9fa",
        ["dark"] = "#212529",
    };
}
