@page "/colors"

<PageTitle>颜色 (Colors) - Bootstrap 展示</PageTitle>

<h2>🎨 颜色与背景 (Colors & Backgrounds)</h2>
<p class="lead">Bootstrap 的颜色体系：主题色、文本颜色、背景色及渐变。</p>

<h5 class="mt-4">主题色 (Theme Colors)</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-4 col-sm-2 col-md text-center">
            <div class="bg-@c.Key text-white rounded p-3 mb-1">@c.Key</div>
            <small class="text-muted">@c.Value</small>
        </div>
    }
</div>

<h5 class="mt-4">背景色（带不透明度）(Background Colors with Opacity)</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-4 col-sm-2 col-md text-center">
            <div class="bg-@c.Key bg-opacity-10 rounded p-3 mb-1 border">10%</div>
            <div class="bg-@c.Key bg-opacity-25 rounded p-3 mb-1 border">25%</div>
            <div class="bg-@c.Key bg-opacity-50 rounded p-3 mb-1 border">50%</div>
            <div class="bg-@c.Key bg-opacity-75 rounded p-3 mb-1 text-white">75%</div>
            <small class="text-muted">@c.Key</small>
        </div>
    }
</div>

<h5 class="mt-4">文本颜色 (Text Colors)</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-4 col-sm-2 col-md text-center">
            <span class="text-@c.Key fw-bold">text-@c.Key</span>
        </div>
    }
</div>
<div class="border rounded p-3 bg-light mb-3">
    <p class="text-muted">柔和文本 <code>.text-muted</code></p>
    <p class="text-black-50">黑色 50% 不透明度文本</p>
    <p class="text-white-50 bg-dark p-2 rounded">白色 50% 不透明度文本（深色背景）</p>
</div>

<h5 class="mt-4">背景渐变 (Background Gradients)</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors.Take(6))
    {
        <div class="col-4 col-sm-2 text-center">
            <div class="bg-@c.Key bg-gradient text-white rounded p-3">@c.Key 渐变</div>
        </div>
    }
</div>

<h5 class="mt-4">边框 (Borders)</h5>
<div class="row g-2 mb-3">
    @foreach (var c in themeColors)
    {
        <div class="col-auto mb-2">
            <span class="border border-@c.Key rounded p-2">border-@c.Key</span>
        </div>
    }
</div>
<div class="border rounded p-3 bg-light">
    <span class="border rounded p-2 m-1">圆角 (rounded)</span>
    <span class="border rounded-circle p-3 m-1">圆形 (circle)</span>
    <span class="border rounded-pill px-3 py-1 m-1">药丸形 (pill)</span>
    <span class="border border-2 p-2 m-1">2px 边框</span>
    <span class="border border-4 p-2 m-1">4px 边框</span>
</div>

<h5 class="mt-4">深色模式 (Dark Mode)</h5>
<div class="rounded p-4 text-bg-dark">
    <h5>深色主题区域</h5>
    <p>使用 <code>text-bg-dark</code> 实现深色背景配浅色文本。</p>
    <span class="badge text-bg-light">深色背景上的浅色徽章</span>
</div>

<div class="rounded p-4 text-bg-secondary mt-3">
    <h5>次要主题区域</h5>
    <p>使用 <code>text-bg-secondary</code>。</p>
</div>

@code {
    private readonly Dictionary<string, string> themeColors = new()
    {
        ["primary"] = "#0d6efd",
        ["secondary"] = "#6c757d",
        ["success"] = "#198754",
        ["danger"] = "#dc3545",
        ["warning"] = "#ffc107",
        ["info"] = "#0dcaf0",
        ["light"] = "#f8f9fa",
        ["dark"] = "#212529",
    };
}
