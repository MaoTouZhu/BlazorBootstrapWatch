@page "/buttons"
@rendermode InteractiveServer

<PageTitle>Buttons & Badges - Bootstrap Showcase</PageTitle>

<h2>🔘 Buttons, Groups & Badges</h2>
<p class="lead">Button variants, sizes, outlines, button groups, toolbars, and badges.</p>

<h5 class="mt-4">Button Variants</h5>
<div class="border rounded p-4 bg-light mb-3">
    @foreach (var v in variants)
    {
        <button type="button" class="btn btn-@v m-1">@v</button>
    }
</div>

<h5>Outline Buttons</h5>
<div class="border rounded p-4 bg-light mb-3">
    @foreach (var v in variants.Take(7))
    {
        <button type="button" class="btn btn-outline-@v m-1">outline-@v</button>
    }
</div>

<h5>Button Sizes</h5>
<div class="border rounded p-4 bg-light mb-3">
    <button type="button" class="btn btn-primary btn-lg m-1">Large button</button>
    <button type="button" class="btn btn-primary m-1">Default button</button>
    <button type="button" class="btn btn-primary btn-sm m-1">Small button</button>
</div>

<h5>Block Button & Disabled</h5>
<div class="border rounded p-4 bg-light mb-3">
    <div class="d-grid gap-2 mb-3">
        <button class="btn btn-primary" type="button">Block-level button (d-grid)</button>
        <button class="btn btn-outline-secondary" type="button">Another block button</button>
    </div>
    <button type="button" class="btn btn-primary m-1" disabled>Disabled primary</button>
    <a class="btn btn-secondary m-1 disabled" role="button" aria-disabled="true">Disabled link</a>
</div>

<h5>Interactive Button (Blazor)</h5>
<div class="border rounded p-4 bg-light mb-4 text-center">
    <button class="btn btn-lg btn-success me-2" @onclick="Increment">👍 Like (@count)</button>
    <button class="btn btn-lg btn-danger" @onclick="Decrement">👎 Dislike</button>
    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="Reset">Reset</button>
</div>

<h5>Button Groups</h5>
<div class="border rounded p-4 bg-light mb-3">
    <div class="btn-group mb-3 me-2" role="group">
        <button type="button" class="btn btn-primary">Left</button>
        <button type="button" class="btn btn-primary">Middle</button>
        <button type="button" class="btn btn-primary">Right</button>
    </div>
    <div class="btn-group mb-3 me-2" role="group">
        <button type="button" class="btn btn-outline-secondary">B</button>
        <button type="button" class="btn btn-outline-secondary">I</button>
        <button type="button" class="btn btn-outline-secondary">U</button>
    </div>
</div>

<div class="border rounded p-4 bg-light mb-3">
    <div class="btn-toolbar">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-primary">1</button>
            <button type="button" class="btn btn-primary">2</button>
            <button type="button" class="btn btn-primary">3</button>
        </div>
        <div class="btn-group me-2">
            <button type="button" class="btn btn-success">Copy</button>
            <button type="button" class="btn btn-success">Paste</button>
        </div>
        <div class="btn-group">
            <button type="button" class="btn btn-info text-white">🔍</button>
        </div>
    </div>
    <small class="text-muted mt-2 d-block">Button toolbar (multiple groups)</small>
</div>

<h5>Vertical Button Group</h5>
<div class="border rounded p-4 bg-light mb-3">
    <div class="btn-group-vertical">
        <button type="button" class="btn btn-primary">Top</button>
        <button type="button" class="btn btn-primary">Middle</button>
        <button type="button" class="btn btn-primary">Bottom</button>
    </div>
</div>

<h5 class="mt-4">Badges</h5>
<div class="border rounded p-4 bg-light mb-3">
    <h1>Heading <span class="badge bg-secondary">New</span></h1>
    <h3>Heading <span class="badge bg-secondary">3</span></h3>
</div>
<div class="border rounded p-4 bg-light mb-3">
    @foreach (var v in variants)
    {
        <span class="badge bg-@v m-1">@v</span>
    }
</div>
<div class="border rounded p-4 bg-light mb-3">
    <span class="badge rounded-pill bg-primary m-1">Primary pill</span>
    <span class="badge rounded-pill bg-success m-1">Success pill</span>
    <span class="badge rounded-pill bg-danger m-1">Danger pill</span>
    <span class="badge rounded-pill bg-warning text-dark m-1">Warning pill</span>
</div>
<div class="border rounded p-4 bg-light mb-3">
    <button type="button" class="btn btn-primary position-relative m-2">
        Messages
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            @count <span class="visually-hidden">unread messages</span>
        </span>
    </button>
    <button type="button" class="btn btn-outline-secondary position-relative m-2">
        Alerts
        <span class="position-absolute top-0 start-100 translate-middle p-2 bg-danger border border-light rounded-circle">
            <span class="visually-hidden">New alerts</span>
        </span>
    </button>
</div>

@code {
    private int count;
    private string[] variants = ["primary","secondary","success","danger","warning","info","light","dark"];

    private void Increment() => count++;
    private void Decrement() => count--;
    private void Reset() => count = 0;
}
