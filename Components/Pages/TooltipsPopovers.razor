@page "/tooltips-popovers"

<PageTitle>Tooltips & Popovers - Bootstrap Showcase</PageTitle>

<h2>💬 Tooltips & Popovers</h2>
<p class="lead">Floating info overlays: tooltips for simple hints, popovers for richer content.</p>

<div class="alert alert-info">
    ⚠️ Tooltips and popovers require JavaScript initialization. The <code>bootstrap-reinit.js</code>
    script handles this automatically after page navigation. Hover over the elements below.
</div>

<h5 class="mt-4">Tooltip Directions</h5>
<div class="border rounded p-5 bg-light mb-4 d-flex flex-wrap justify-content-center gap-3">
    <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="top" title="Tooltip on top">
        Top
    </button>
    <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="right" title="Tooltip on right">
        Right
    </button>
    <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Tooltip on bottom">
        Bottom
    </button>
    <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="left" title="Tooltip on left">
        Left
    </button>
</div>

<h5>Tooltip on Links & Icons</h5>
<div class="border rounded p-4 bg-light mb-4">
    <p>
        Hover over this
        <a href="#" data-bs-toggle="tooltip" title="Default tooltip">link with tooltip</a>
        or this
        <span class="badge bg-primary" data-bs-toggle="tooltip" title="Badge tooltip!">badge</span>
        to see tooltips.
    </p>
    <p>
        <button type="button" class="btn btn-link" data-bs-toggle="tooltip" data-bs-title="Custom title attribute">
            Using data-bs-title
        </button>
    </p>
</div>

<h5 class="mt-4">Popover Directions</h5>
<div class="border rounded p-5 bg-light mb-4 d-flex flex-wrap justify-content-center gap-3">
    <button type="button" class="btn btn-danger"
            data-bs-toggle="popover" data-bs-placement="top"
            data-bs-title="Top Popover"
            data-bs-content="This popover appears above the button.">
        Popover Top
    </button>
    <button type="button" class="btn btn-danger"
            data-bs-toggle="popover" data-bs-placement="right"
            data-bs-title="Right Popover"
            data-bs-content="This popover appears to the right.">
        Popover Right
    </button>
    <button type="button" class="btn btn-danger"
            data-bs-toggle="popover" data-bs-placement="bottom"
            data-bs-title="Bottom Popover"
            data-bs-content="This popover appears below the button.">
        Popover Bottom
    </button>
    <button type="button" class="btn btn-danger"
            data-bs-toggle="popover" data-bs-placement="left"
            data-bs-title="Left Popover"
            data-bs-content="This popover appears to the left.">
        Popover Left
    </button>
</div>

<h5>Dismissible Popover</h5>
<div class="border rounded p-4 bg-light mb-4">
    <button type="button" class="btn btn-warning"
            data-bs-toggle="popover" data-bs-trigger="focus"
            data-bs-title="Dismissible Popover"
            data-bs-content="Click the button to show. Click elsewhere to dismiss (uses focus trigger).">
        Click to Toggle (focus)
    </button>
    <small class="text-muted ms-2">Dismiss by clicking outside.</small>
</div>

<h5>Popover with Custom HTML</h5>
<div class="border rounded p-4 bg-light mb-4">
    <button type="button" class="btn btn-success"
            data-bs-toggle="popover"
            data-bs-title="<strong>HTML Content</strong>"
            data-bs-html="true"
            data-bs-content='<div><p>Popovers can contain <strong>HTML</strong>.</p><ul class="mb-0"><li>List item 1</li><li>List item 2</li></ul></div>'>
        Popover with HTML
    </button>
    <small class="text-muted ms-2">Requires <code>data-bs-html="true"</code>.</small>
</div>
