@page "/typography"

<PageTitle>Typography - Bootstrap Showcase</PageTitle>

<h2>🔤 Typography</h2>
<p class="lead">Headings, display text, inline elements, lists, and text utilities.</p>

<h5 class="mt-4">Headings</h5>
<div class="border rounded p-3 bg-light">
    <h1>h1. Heading <small class="text-muted">2.5rem</small></h1>
    <h2>h2. Heading <small class="text-muted">2rem</small></h2>
    <h3>h3. Heading <small class="text-muted">1.75rem</small></h3>
    <h4>h4. Heading <small class="text-muted">1.5rem</small></h4>
    <h5>h5. Heading <small class="text-muted">1.25rem</small></h5>
    <h6>h6. Heading <small class="text-muted">1rem</small></h6>
</div>

<h5 class="mt-4">Display Headings</h5>
<div class="border rounded p-3 bg-light">
    <h1 class="display-1">Display 1</h1>
    <h1 class="display-4">Display 4</h1>
    <h1 class="display-6">Display 6</h1>
</div>

<h5 class="mt-4">Lead Paragraph</h5>
<div class="border rounded p-3 bg-light">
    <p class="lead">This is a lead paragraph — wider line-height, larger font weight.</p>
    <p>Normal paragraph text for comparison.</p>
</div>

<h5 class="mt-4">Inline Text Elements</h5>
<div class="border rounded p-3 bg-light">
    <p><mark>Highlighted text</mark> using <code>&lt;mark&gt;</code>.</p>
    <p><del>Deleted text</del> and <s>strikethrough text</s>.</p>
    <p><ins>Inserted text</ins> and <u>underlined text</u>.</p>
    <p><small>Fine print</small> and <strong>bold text</strong> and <em>italicized text</em>.</p>
    <p><abbr title="HyperText Markup Language">HTML</abbr> abbreviation with tooltip.</p>
    <blockquote class="blockquote">
        <p>A well-known quote, contained in a blockquote element.</p>
        <footer class="blockquote-footer">Someone famous in <cite>Source Title</cite></footer>
    </blockquote>
</div>

<h5 class="mt-4">Lists</h5>
<div class="row">
    <div class="col-md-6">
        <div class="border rounded p-3 bg-light mb-3">
            <ul>
                <li>Unordered list item</li>
                <li>Another item
                    <ul><li>Nested item</li><li>Another nested</li></ul>
                </li>
                <li>Third item</li>
            </ul>
            <ol>
                <li>Ordered list item</li>
                <li>Second item</li>
                <li>Third item</li>
            </ol>
        </div>
    </div>
    <div class="col-md-6">
        <div class="border rounded p-3 bg-light mb-3">
            <ul class="list-unstyled">
                <li>Unstyled list item</li>
                <li>Another unstyled item</li>
            </ul>
            <ul class="list-inline">
                <li class="list-inline-item">Inline item 1</li>
                <li class="list-inline-item">Inline item 2</li>
                <li class="list-inline-item">Inline item 3</li>
            </ul>
            <dl class="row">
                <dt class="col-sm-3">Term</dt>
                <dd class="col-sm-9">Description for the term.</dd>
                <dt class="col-sm-3">Another</dt>
                <dd class="col-sm-9">Another description.</dd>
            </dl>
        </div>
    </div>
</div>

<h5 class="mt-4">Text Utilities</h5>
<div class="border rounded p-3 bg-light">
    <p class="text-start">Left-aligned text (start).</p>
    <p class="text-center">Center-aligned text.</p>
    <p class="text-end">Right-aligned text (end).</p>
    <p class="text-lowercase">LOWERCASED text.</p>
    <p class="text-uppercase">uppercased text.</p>
    <p class="text-capitalize">capitalized text.</p>
    <p class="fw-bold">Bold text (fw-bold).</p>
    <p class="fst-italic">Italic text (fst-italic).</p>
    <p class="fw-light">Light weight text.</p>
    <p class="text-decoration-underline">Underlined text.</p>
    <p class="text-decoration-line-through">Line-through text.</p>
    <p class="text-truncate" style="max-width:200px">This text is truncated with an ellipsis when it overflows.</p>
</div>
