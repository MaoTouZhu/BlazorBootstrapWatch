@page "/tables"

<PageTitle>Tables - Bootstrap Showcase</PageTitle>

<h2>📊 Tables</h2>
<p class="lead">Table variants: basic, striped, hover, bordered, borderless, responsive, colored, and small.</p>

<h5 class="mt-4">Basic & Striped</h5>
<div class="table-responsive mb-4">
    <table class="table table-striped">
        <thead class="table-dark">
            <tr><th>#</th><th>Name</th><th>Role</th><th>Status</th></tr>
        </thead>
        <tbody>
            <tr><td>1</td><td>Alice Chen</td><td>Developer</td><td><span class="badge bg-success">Active</span></td></tr>
            <tr><td>2</td><td>Bob Smith</td><td>Designer</td><td><span class="badge bg-warning">Away</span></td></tr>
            <tr><td>3</td><td>Carol Davis</td><td>Manager</td><td><span class="badge bg-success">Active</span></td></tr>
            <tr><td>4</td><td>Dave Wilson</td><td>QA</td><td><span class="badge bg-danger">Offline</span></td></tr>
        </tbody>
    </table>
</div>

<h5>Hover & Bordered</h5>
<div class="table-responsive mb-4">
    <table class="table table-hover table-bordered">
        <thead class="table-primary">
            <tr><th>#</th><th>Product</th><th>Price</th><th>Stock</th></tr>
        </thead>
        <tbody>
            <tr><td>1</td><td>Widget A</td><td>$9.99</td><td>142</td></tr>
            <tr><td>2</td><td>Gadget B</td><td>$24.99</td><td>87</td></tr>
            <tr><td>3</td><td>Doohickey C</td><td>$14.99</td><td>0</td></tr>
        </tbody>
    </table>
</div>

<h5>Small & Borderless</h5>
<div class="table-responsive mb-4">
    <table class="table table-sm table-borderless">
        <thead><tr><th>#</th><th>Item</th><th>Qty</th></tr></thead>
        <tbody>
            <tr><td>1</td><td>Apples</td><td>5</td></tr>
            <tr><td>2</td><td>Oranges</td><td>3</td></tr>
            <tr><td>3</td><td>Bananas</td><td>8</td></tr>
        </tbody>
    </table>
</div>

<h5>Contextual Rows</h5>
<div class="table-responsive mb-4">
    <table class="table">
        <thead><tr><th>Class</th><th>Effect</th></tr></thead>
        <tbody>
            <tr class="table-active"><td>.table-active</td><td>Active row highlight</td></tr>
            <tr class="table-primary"><td>.table-primary</td><td>Primary row highlight</td></tr>
            <tr class="table-success"><td>.table-success</td><td>Success row highlight</td></tr>
            <tr class="table-danger"><td>.table-danger</td><td>Danger row highlight</td></tr>
            <tr class="table-warning"><td>.table-warning</td><td>Warning row highlight</td></tr>
            <tr class="table-info"><td>.table-info</td><td>Info row highlight</td></tr>
        </tbody>
    </table>
</div>

<h5>Responsive Table (scroll horizontally on small screens)</h5>
<div class="table-responsive">
    <table class="table table-striped">
        <thead><tr><th>#</th><th>Column A</th><th>Column B</th><th>Column C</th><th>Column D</th><th>Column E</th><th>Column F</th></tr></thead>
        <tbody>
            <tr><td>1</td><td>Data</td><td>Data</td><td>Data</td><td>Data</td><td>Data</td><td>Data</td></tr>
            <tr><td>2</td><td>Data</td><td>Data</td><td>Data</td><td>Data</td><td>Data</td><td>Data</td></tr>
        </tbody>
    </table>
</div>
