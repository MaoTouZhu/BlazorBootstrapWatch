@page "/context-menu"
@rendermode InteractiveServer

<PageTitle>右键菜单 (Context Menu) - Blazor 特性</PageTitle>

<h2>🖱️ 右键菜单 (Context Menu)</h2>
<p class="lead">纯 Blazor 实现：<code>@@oncontextmenu:preventDefault</code> 阻止浏览器原生菜单，自定义菜单定位在鼠标位置。</p>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="border rounded p-4 bg-light">
            <h5>右键点击下方卡片</h5>
            <p class="small text-muted">每张卡片有独立的右键菜单，菜单跟随鼠标位置显示。点击空白处关闭。</p>
            <div class="row g-3">
                @foreach (var box in boxes)
                {
                    <div class="col-6 col-md-3">
                        <div class="border rounded p-4 text-center bg-white position-relative shadow-sm"
                             style="background:@box.Bg!important;min-height:120px;cursor:context-menu;transition:transform 0.15s"
                             @oncontextmenu:preventDefault
                             @oncontextmenu="(e) => OpenMenu(e, box)">
                            <div class="display-6 mb-2">@box.Icon</div>
                            <span class="fw-bold @(box.DarkText ? "text-dark" : "text-white")">@box.Name</span>
                            <small class="d-block mt-1 @(box.DarkText ? "text-secondary" : "text-white-50")">右键点击</small>
                        </div>
                    </div>
                }
            </div>

            @if (menu.Visible)
            {
                <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index:1050"
                     @onclick="CloseMenu" @oncontextmenu:preventDefault @oncontextmenu="CloseMenu">
                </div>
                <div class="position-fixed bg-white border rounded shadow-lg py-1"
                     style="left:@(menu.X.ToString("F0"))px;top:@(menu.Y.ToString("F0"))px;z-index:1051;min-width:200px"
                     @onclick:stopPropagation>
                    <div class="px-3 py-2">
                        <strong>@menu.Target</strong>
                        <small class="text-muted d-block">@menu.Desc</small>
                    </div>
                    <div class="dropdown-divider my-1"></div>
                    <button class="dropdown-item" @onclick='() => DoAction("Copy")'>
                        📋 复制 (Copy)
                    </button>
                    <button class="dropdown-item" @onclick='() => DoAction("Rename")'>
                        ✏️ 重命名 (Rename)
                    </button>
                    <button class="dropdown-item" @onclick='() => DoAction("Details")'>
                        🔍 查看详情 (Details)
                    </button>
                    <div class="dropdown-divider my-1"></div>
                    <button class="dropdown-item text-danger" @onclick='() => DoAction("Delete")'>
                        🗑 删除 (Delete)
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(result))
            {
                <div class="alert alert-info mt-3 mb-0 py-2 d-flex justify-content-between align-items-center">
                    <span>@result</span>
                    <button class="btn-close" @onclick='() => result = ""'></button>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="border rounded p-4 bg-light h-100">
            <h5>实现要点</h5>
            <ul class="small mb-0">
                <li class="mb-2"><code>@@oncontextmenu:preventDefault</code><br>阻止浏览器默认右键菜单</li>
                <li class="mb-2"><code>@@oncontextmenu</code><br>捕获右键事件，获取 <code>ClientX/Y</code></li>
                <li class="mb-2"><code>position:fixed</code><br>菜单相对视口定位，不受滚动影响</li>
                <li class="mb-2"><strong>全屏透明遮罩</strong><br>捕获点击事件关闭菜单</li>
                <li class="mb-2"><code>@@onclick:stopPropagation</code><br>菜单内部点击不冒泡</li>
                <li><strong>元组状态</strong><br><code>(bool Visible, double X, double Y, string Target, string Desc)</code> 管理菜单状态</li>
            </ul>
        </div>
    </div>
</div>

@code {
    private (bool Visible, double X, double Y, string Target, string Desc) menu;
    private string result = "";

    private readonly List<(string Icon, string Name, string Bg, bool DarkText, string Desc)> boxes = new()
    {
        ("📁", "文件夹", "#0d6efd", false, "包含 12 个文件"),
        ("🖼️", "图片库", "#198754", false, "包含 47 张图片"),
        ("📝", "文档", "#ffc107", true, "最近修改：今天"),
        ("⚙️", "设置", "#6c757d", false, "系统配置项"),
    };

    private void OpenMenu(MouseEventArgs e, (string, string Name, string, bool, string Desc) box)
    {
        menu = (true, e.ClientX, e.ClientY, box.Name, box.Desc);
    }

    private void CloseMenu() => menu = default;

    private void DoAction(string action)
    {
        var labels = new Dictionary<string, string>
        {
            ["Copy"] = "📋 复制", ["Rename"] = "✏️ 重命名",
            ["Details"] = "🔍 查看详情", ["Delete"] = "🗑 删除"
        };
        result = $"对「{menu.Target}」执行了「{labels.GetValueOrDefault(action, action)}」操作 —— {DateTime.Now:HH:mm:ss}";
        menu = default;
    }
}
