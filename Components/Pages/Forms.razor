@page "/forms"
@rendermode InteractiveServer

<PageTitle>Forms - Bootstrap Showcase</PageTitle>

<h2>📝 Forms</h2>
<p class="lead">Form controls, input types, validation, input groups, and floating labels.</p>

<h5 class="mt-4">Basic Inputs</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="mb-3">
        <label for="email" class="form-label">Email address</label>
        <input type="email" class="form-control" id="email" placeholder="name@example.com">
        <div class="form-text">We'll never share your email.</div>
    </div>
    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control" id="password" placeholder="Password">
    </div>
</div>

<h5>Select, Textarea, Range, Datalist</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <select class="form-select" id="country">
            <option selected>Choose...</option>
            <option value="1">United States</option>
            <option value="2">Canada</option>
            <option value="3">United Kingdom</option>
        </select>
    </div>
    <div class="mb-3">
        <label for="bio" class="form-label">Bio</label>
        <textarea class="form-control" id="bio" rows="2" placeholder="Tell us about yourself..."></textarea>
    </div>
    <div class="mb-3">
        <label for="range" class="form-label">Satisfaction: @rangeValue%</label>
        <input type="range" class="form-range" id="range" min="0" max="100" @bind="rangeValue">
    </div>
</div>

<h5>Checks, Radios & Switches</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" value="" id="check1" checked>
        <label class="form-check-label" for="check1">Default checkbox (checked)</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" value="" id="check2">
        <label class="form-check-label" for="check2">Unchecked checkbox</label>
    </div>
    <hr>
    <div class="form-check">
        <input class="form-check-input" type="radio" name="radioDemo" id="radio1" checked>
        <label class="form-check-label" for="radio1">Option A</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="radio" name="radioDemo" id="radio2">
        <label class="form-check-label" for="radio2">Option B</label>
    </div>
    <hr>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="switch1" checked>
        <label class="form-check-label" for="switch1">Toggle switch (on)</label>
    </div>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="switch2">
        <label class="form-check-label" for="switch2">Toggle switch (off)</label>
    </div>
</div>

<h5>Input Groups</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="input-group mb-3">
        <span class="input-group-text">@@</span>
        <input type="text" class="form-control" placeholder="Username">
    </div>
    <div class="input-group mb-3">
        <span class="input-group-text">$</span>
        <input type="text" class="form-control" placeholder="Amount">
        <span class="input-group-text">.00</span>
    </div>
    <div class="input-group mb-3">
        <input type="text" class="form-control" placeholder="Search...">
        <button class="btn btn-primary" type="button">🔍 Search</button>
    </div>
</div>

<h5>Floating Labels</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="form-floating mb-3">
        <input type="email" class="form-control" id="floatingEmail" placeholder="name@example.com">
        <label for="floatingEmail">Email address</label>
    </div>
    <div class="form-floating">
        <select class="form-select" id="floatingSelect">
            <option selected>Open this menu</option>
            <option value="1">Option One</option>
            <option value="2">Option Two</option>
        </select>
        <label for="floatingSelect">Works with selects</label>
    </div>
</div>

<h5>Form Validation (Interactive)</h5>
<div class="border rounded p-4 bg-light mb-4">
    <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="demo-form">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label for="name" class="form-label">Name (required)</label>
            <InputText id="name" class="form-control" @bind-Value="formModel.Name" />
            <ValidationMessage For="() => formModel.Name" />
        </div>
        <div class="mb-3">
            <label for="formEmail" class="form-label">Email (required, valid format)</label>
            <InputText id="formEmail" class="form-control" @bind-Value="formModel.Email" />
            <ValidationMessage For="() => formModel.Email" />
        </div>
        <div class="mb-3 form-check">
            <InputCheckbox id="agree" class="form-check-input" @bind-Value="formModel.Agree" />
            <label class="form-check-label" for="agree">I agree to the terms</label>
            <ValidationMessage For="() => formModel.Agree" />
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
        @if (submitted)
        {
            <div class="alert alert-success mt-3">✅ Form submitted successfully! Welcome, @formModel.Name.</div>
        }
    </EditForm>
</div>

<h5>Horizontal Form</h5>
<div class="border rounded p-4 bg-light mb-4">
    <div class="row mb-3">
        <label for="hEmail" class="col-sm-2 col-form-label">Email</label>
        <div class="col-sm-10">
            <input type="email" class="form-control" id="hEmail" placeholder="Email">
        </div>
    </div>
    <div class="row mb-3">
        <label for="hPass" class="col-sm-2 col-form-label">Password</label>
        <div class="col-sm-10">
            <input type="password" class="form-control" id="hPass" placeholder="Password">
        </div>
    </div>
</div>

<h5>Disabled & Readonly</h5>
<div class="border rounded p-4 bg-light mb-4">
    <input class="form-control mb-3" type="text" placeholder="Disabled input" disabled>
    <input class="form-control mb-3" type="text" value="Readonly value" readonly>
    <select class="form-select" disabled>
        <option>Disabled select</option>
    </select>
</div>

<h5>Sizing</h5>
<div class="border rounded p-4 bg-light mb-4">
    <input class="form-control form-control-lg mb-2" type="text" placeholder="Large input (.form-control-lg)">
    <input class="form-control mb-2" type="text" placeholder="Default input">
    <input class="form-control form-control-sm" type="text" placeholder="Small input (.form-control-sm)">
</div>

@code {
    private int rangeValue = 50;
    private bool submitted;
    private FormModel formModel = new();

    private void HandleSubmit()
    {
        submitted = true;
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Valid email required.")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Range(typeof(bool), "true", "true", ErrorMessage = "You must agree.")]
        public bool Agree { get; set; }
    }
}
